# =============================================================================
# Encrypted P2P Chat — Environment Variables
# Copy this file to .env and fill in the values before running docker-compose
# =============================================================================

# PostgreSQL
POSTGRES_USER=e2echat
POSTGRES_PASSWORD=changeme_strong_password_32chars!
POSTGRES_DB=e2echat

# Redis
REDIS_PASSWORD=changeme_redis_password_24chars!

# SurrealDB
SURREAL_USER=root
SURREAL_PASS=changeme_surreal_password_24!
SURREAL_NS=e2echat
SURREAL_DB=messages

# FastAPI Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_this_to_a_64_char_hex_secret_key_generated_with_secrets_module

# WebAuthn / Passkeys
# RP_ID must match the domain serving the frontend (e.g., "localhost" for local dev)
RP_ID=localhost
RP_NAME=Encrypted P2P Chat
# RP_ORIGIN must be the exact origin of the frontend (e.g., "http://localhost" or "https://chat.example.com")
RP_ORIGIN=http://localhost

# CORS
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# Debug (set to false in production)
DEBUG=false
